  id_genero                Int?
  id_estado_civil          Int?
  departamento             String?                    @db.VarChar(100)
  ciudad                   String?                    @db.VarChar(100)
  id_ciudad                Int?
  direccion                String?                    @db.VarChar(200)
  grupo_poblacional        String?                    @db.VarChar(50)
  grupo_poblacional_otro   String?                    @db.VarChar(150)
