generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model acompanantes {
  id_acompanante        Int       @id @default(autoincrement())
  id_paciente           Int
  nombre                String    @db.VarChar(150)
  direccion             String?   @db.VarChar(200)
  telefono              String?   @db.VarChar(50)
  relacion_con_paciente String?   @db.VarChar(100)
  pacientes             pacientes @relation(fields: [id_paciente], references: [id_paciente], onDelete: Cascade, onUpdate: NoAction)
}

model archivos_adjuntos {
  id_archivo       Int       @id @default(autoincrement())
  entidad          String    @db.VarChar(50)
  id_entidad       Int
  nombre_archivo   String    @db.VarChar(255)
  ruta             String    @db.VarChar(500)
  tipo_mime        String?   @db.VarChar(100)
  tamano_bytes     BigInt?
  id_usuario_subio Int?
  fecha_subida     DateTime  @default(now()) @db.Timestamp(6)
  usuarios         usuarios? @relation(fields: [id_usuario_subio], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([entidad, id_entidad], map: "idx_adjuntos_entidad")
}

model atenciones_salud {
  id_atencion                           Int                                   @id @default(autoincrement())
  id_historia                           Int
  id_profesional                        Int?
  id_tipo_atencion                      Int?
  id_modalidad_atencion                 Int?
  id_cita                               Int?
  fecha_hora                            DateTime                              @default(now()) @db.Timestamp(6)
  analisis                              String?
  llega_por_sus_medios                  Boolean?
  llega_por_sus_medios_cual             String?                               @db.VarChar(120)
  estado_a_la_llegada                   String?                               @db.VarChar(20)
  caso_accidente_intoxicacion_violencia Boolean?
  fecha_ocurrencia_evento               DateTime?                             @db.Date
  lugar_ocurrencia_evento               String?                               @db.VarChar(150)
  notificacion_policia                  Boolean?
  notificacion_cti                      Boolean?
  notificacion_acudiente                Boolean?
  notificacion_otro                     Boolean?
  notificacion_otro_cual                String?                               @db.VarChar(120)
  hc_anamnesis_atencion                 hc_anamnesis_atencion?
  hc_antecedentes_atencion              hc_antecedentes_atencion[]
  hc_antecedentes_traumaticos_atencion  hc_antecedentes_traumaticos_atencion?
  hc_atencion_cierre                    hc_atencion_cierre?
  hc_ssr_atencion                       hc_ssr_atencion?
  hc_habitos_atencion                   hc_habitos_atencion?
  hc_tamizajes_atencion                 hc_tamizajes_atencion?
  hc_examen_fisico_atencion             hc_examen_fisico_atencion?
  hc_valoracion_sistemas_atencion       hc_valoracion_sistemas_atencion?
  historias_clinicas                    historias_clinicas                    @relation(fields: [id_historia], references: [id_historia], onDelete: Cascade, onUpdate: NoAction)
  modalidades_atencion                  modalidades_atencion?                 @relation(fields: [id_modalidad_atencion], references: [id_modalidad_atencion], onDelete: NoAction, onUpdate: NoAction)
  profesionales_salud                   profesionales_salud?                  @relation(fields: [id_profesional], references: [id_profesional], onDelete: NoAction, onUpdate: NoAction)
  tipos_atencion                        tipos_atencion?                       @relation(fields: [id_tipo_atencion], references: [id_tipo_atencion], onDelete: NoAction, onUpdate: NoAction)
  citas                                 citas?                                @relation(fields: [id_cita], references: [id_cita], onDelete: NoAction, onUpdate: NoAction, map: "fk_atencion_cita")
  certificados_medicos                  certificados_medicos[]
  consentimientos_paciente              consentimientos_paciente[]
  desistimientos_programa               desistimientos_programa[]
  diagnosticos_atencion                 diagnosticos_atencion[]
  eventos_seguimiento_cronico           eventos_seguimiento_cronico[]
  examenes_diagnosticos                 examenes_diagnosticos[]
  formulas_medicas                      formulas_medicas[]
  recomendaciones_medicas               recomendaciones_medicas[]
  rutas_activadas_atencion              rutas_activadas_atencion[]
}

model hc_anamnesis_atencion {
  id_hc_anamnesis   Int              @id @default(autoincrement())
  id_atencion       Int              @unique
  motivo_consulta   String?
  enfermedad_actual String?
  fecha_creacion    DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud  atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_anamnesis_atencion")
}

model hc_antecedentes_atencion {
  id_hc_antecedente Int              @id @default(autoincrement())
  id_atencion       Int
  diagnostico       String?          @db.VarChar(255)
  tipo_antecedente  String?          @db.VarChar(50)
  observacion       String?
  fecha_creacion    DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud  atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_antecedentes_atencion")
}

model hc_antecedentes_traumaticos_atencion {
  id_hc_antecedente_traumatico Int              @id @default(autoincrement())
  id_atencion                  Int              @unique
  naturaleza_lesion            String?          @db.VarChar(255)
  fecha_ocurrencia             DateTime?        @db.Date
  secuelas                     String?
  fecha_creacion               DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud             atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_antecedentes_traumaticos_atencion")
}

model hc_atencion_cierre {
  id_hc_atencion_cierre        Int              @id @default(autoincrement())
  id_atencion                  Int              @unique
  conducta_plan_estudio_manejo String?
  recomendaciones              String?
  certificado_emitido          Boolean?
  certificado_opcion           String?          @db.VarChar(50)
  certificado_restricciones    String?
  certificado_recomendaciones  String?
  notificacion_emitida         Boolean?
  seguimiento_notificacion     String?          @db.VarChar(50)
  notificacion_observaciones   String?
  seguimiento_opcion           String?          @db.VarChar(50)
  seguimiento_efectivo         Boolean?
  cierre_seguimiento           Boolean?
  seguimiento_fecha            DateTime?        @db.Date
  fecha_creacion               DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud             atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_atencion_cierre")
}

model hc_ssr_atencion {
  id_hc_ssr        Int              @id @default(autoincrement())
  id_atencion      Int              @unique
  contenido        String?
  fecha_creacion   DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_ssr_atencion")
}

model hc_habitos_atencion {
  id_hc_habitos           Int              @id @default(autoincrement())
  id_atencion             Int              @unique
  tabaco_cigarrillo       String?          @db.VarChar(255)
  alcohol                 String?          @db.VarChar(255)
  sustancias_psicoactivas String?          @db.VarChar(255)
  otros                   String?          @db.VarChar(255)
  actividad_fisica        String?          @db.VarChar(255)
  alimentacion            String?          @db.VarChar(255)
  otras_actividades       String?          @db.VarChar(255)
  fecha_creacion          DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud        atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_habitos_atencion")
}

model hc_tamizajes_atencion {
  id_hc_tamizaje   Int              @id @default(autoincrement())
  id_atencion      Int              @unique
  contenido        String?
  fecha_creacion   DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_tamizajes_atencion")
}

model hc_examen_fisico_atencion {
  id_hc_examen_fisico Int              @id @default(autoincrement())
  id_atencion         Int              @unique
  contenido           String?
  fecha_creacion      DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud    atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_examen_fisico_atencion")
}

model hc_valoracion_sistemas_atencion {
  id_hc_valoracion_sistemas Int              @id @default(autoincrement())
  id_atencion               Int              @unique
  contenido                 String?
  fecha_creacion            DateTime         @default(now()) @db.Timestamp(6)
  atenciones_salud          atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_atencion], map: "idx_hc_val_sistemas_atencion")
}

model auditoria {
  id_auditoria Int       @id @default(autoincrement())
  id_usuario   Int?
  tabla        String    @db.VarChar(100)
  id_registro  String    @db.VarChar(100)
  accion       String    @db.VarChar(20)
  fecha_hora   DateTime  @default(now()) @db.Timestamp(6)
  detalle      String?
  usuarios     usuarios? @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
}

model catalogo_examenes {
  id_examen_catalogo    Int                     @id @default(autoincrement())
  nombre                String                  @db.VarChar(150)
  id_tipo_examen        Int
  activo                Boolean                 @default(true)
  tipos_examen          tipos_examen            @relation(fields: [id_tipo_examen], references: [id_tipo_examen], onDelete: NoAction, onUpdate: NoAction)
  examenes_diagnosticos examenes_diagnosticos[]
}

model catalogo_medicamentos {
  id_medicamento   Int             @id @default(autoincrement())
  nombre_generico  String          @db.VarChar(150)
  nombre_comercial String?         @db.VarChar(150)
  presentacion     String?         @db.VarChar(100)
  registro_invima  String?         @db.VarChar(50)
  activo           Boolean         @default(true)
  items_formula    items_formula[]
}

model certificados_medicos {
  id_certificado           Int                      @id @default(autoincrement())
  id_atencion              Int
  id_tipo_certificado      Int
  restricciones            String?
  recomendaciones          String?
  fecha_emision            DateTime                 @default(now()) @db.Timestamp(6)
  codigo_verificacion      String?                  @db.VarChar(100)
  firma_digital            String?
  id_usuario_emisor        Int?
  atenciones_salud         atenciones_salud         @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)
  tipos_certificado_medico tipos_certificado_medico @relation(fields: [id_tipo_certificado], references: [id_tipo_certificado], onDelete: NoAction, onUpdate: NoAction)
  usuarios                 usuarios?                @relation(fields: [id_usuario_emisor], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
}

model cie10 {
  codigo                                String                                  @id @db.VarChar(10)
  nombre                                String                                  @db.VarChar(255)
  descripcion                           String?                                 @db.VarChar(255)
  activo                                Boolean                                 @default(true)
  notas_evolucion_historia_diagnosticos notas_evolucion_historia_diagnosticos[]
  diagnosticos_atencion                 diagnosticos_atencion[]
}

model citas {
  id_cita                        Int                   @id @default(autoincrement())
  id_paciente                    Int
  id_profesional                 Int
  id_sede                        Int?
  id_tipo_cita                   Int?
  id_estado_cita                 Int?
  id_modalidad_atencion          Int?
  id_programa_salud              Int?
  fecha_hora_inicio              DateTime              @db.Timestamp(6)
  fecha_hora_fin                 DateTime?             @db.Timestamp(6)
  seguimiento                    Boolean               @default(false)
  tipo_seguimiento               String?               @db.VarChar(30)
  canal_recordatorio             String?               @db.VarChar(50)
  id_historia_vinculada          Int?
  atenciones_salud               atenciones_salud[]
  estados_cita                   estados_cita?         @relation(fields: [id_estado_cita], references: [id_estado_cita])
  pacientes                      pacientes             @relation(fields: [id_paciente], references: [id_paciente])
  profesionales_salud            profesionales_salud   @relation(fields: [id_profesional], references: [id_profesional])
  sedes                          sedes?                @relation(fields: [id_sede], references: [id_sede])
  tipos_cita                     tipos_cita?           @relation(fields: [id_tipo_cita], references: [id_tipo_cita])
  modalidades_atencion           modalidades_atencion? @relation(fields: [id_modalidad_atencion], references: [id_modalidad_atencion])
  programas_salud                programas_salud?      @relation(fields: [id_programa_salud], references: [id_programa_salud])
  tipos_atencion                 tipos_atencion?       @relation(fields: [tipos_atencionId_tipo_atencion], references: [id_tipo_atencion])
  tipos_atencionId_tipo_atencion Int?
  historia_vinculada             historias_clinicas?   @relation("citas_historia_vinculada", fields: [id_historia_vinculada], references: [id_historia], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_paciente], map: "idx_citas_paciente")
  @@index([id_profesional, fecha_hora_inicio], map: "idx_citas_profesional")
  @@index([id_historia_vinculada], map: "idx_citas_historia_vinculada")
}

model consentimientos_paciente {
  id_consentimiento         Int                       @id @default(autoincrement())
  id_paciente               Int
  id_plantilla              Int
  id_atencion               Int?
  id_estado_consentimiento  Int?
  fecha_firma               DateTime                  @default(now()) @db.Timestamp(6)
  firma_paciente            String?
  firma_testigo             String?
  observaciones             String?
  atenciones_salud          atenciones_salud?         @relation(fields: [id_atencion], references: [id_atencion], onDelete: NoAction, onUpdate: NoAction)
  estados_consentimiento    estados_consentimiento?   @relation(fields: [id_estado_consentimiento], references: [id_estado_consentimiento], onDelete: NoAction, onUpdate: NoAction)
  pacientes                 pacientes                 @relation(fields: [id_paciente], references: [id_paciente], onDelete: NoAction, onUpdate: NoAction)
  plantillas_consentimiento plantillas_consentimiento @relation(fields: [id_plantilla], references: [id_plantilla], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_paciente], map: "idx_consent_paciente")
}

model desistimientos_programa {
  id_desistimiento       Int                  @id @default(autoincrement())
  id_programa_paciente   Int
  id_profesional         Int?
  id_atencion            Int?
  fecha                  DateTime             @db.Date
  id_sede                Int?
  motivo_desistimiento   String?
  firma_digital          String?
  compromiso_otras_rutas String?
  atenciones_salud       atenciones_salud?    @relation(fields: [id_atencion], references: [id_atencion], onDelete: NoAction, onUpdate: NoAction)
  profesionales_salud    profesionales_salud? @relation(fields: [id_profesional], references: [id_profesional], onDelete: NoAction, onUpdate: NoAction)
  programas_paciente     programas_paciente   @relation(fields: [id_programa_paciente], references: [id_programa_paciente], onDelete: NoAction, onUpdate: NoAction)
  sedes                  sedes?               @relation(fields: [id_sede], references: [id_sede], onDelete: NoAction, onUpdate: NoAction)
}

model diagnosticos_atencion {
  id_diagnostico                 Int                             @id @default(autoincrement())
  id_atencion                    Int
  codigo_cie10                   String                          @db.VarChar(10)
  es_principal                   Boolean                         @default(false)
  id_tipo_confirmacion           Int?
  cie10                          cie10                           @relation(fields: [codigo_cie10], references: [codigo], onDelete: NoAction, onUpdate: NoAction)
  atenciones_salud               atenciones_salud                @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)
  tipos_confirmacion_diagnostico tipos_confirmacion_diagnostico? @relation(fields: [id_tipo_confirmacion], references: [id_tipo_confirmacion], onDelete: NoAction, onUpdate: NoAction)
  seguimientos_cronicos          seguimientos_cronicos[]

  @@index([id_atencion], map: "idx_diag_atencion")
  @@index([codigo_cie10], map: "idx_diag_cie10")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model disponibilidades_profesional {
  id_disponibilidad     Int                 @id @default(autoincrement())
  id_profesional        Int
  id_sede               Int?
  dia_semana            Int                 @db.SmallInt
  hora_inicio           DateTime            @db.Time(6)
  hora_fin              DateTime            @db.Time(6)
  capacidad_simultanea  Int                 @default(1)
  es_excepcion          Boolean             @default(false)
  fecha_inicio_vigencia DateTime?           @db.Date
  fecha_fin_vigencia    DateTime?           @db.Date
  profesionales_salud   profesionales_salud @relation(fields: [id_profesional], references: [id_profesional], onDelete: Cascade, onUpdate: NoAction)
  sedes                 sedes?              @relation(fields: [id_sede], references: [id_sede], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_profesional, id_sede, dia_semana], map: "idx_disp_prof_sede_dia")
}

model eps {
  id_eps    Int         @id @default(autoincrement())
  nombre    String      @db.VarChar(150)
  nit       String?     @db.VarChar(50)
  pacientes pacientes[]
}

model especialidades {
  id_especialidad     Int                   @id @default(autoincrement())
  nombre              String                @db.VarChar(100)
  descripcion         String?               @db.VarChar(200)
  profesionales_salud profesionales_salud[]
}

model estados_cita {
  id_estado_cita Int     @id @default(autoincrement())
  codigo         String  @unique @db.VarChar(50)
  descripcion    String  @db.VarChar(150)
  citas          citas[]
}

model estados_civiles {
  id_estado_civil Int         @id @default(autoincrement())
  codigo          String      @unique @db.VarChar(20)
  descripcion     String      @db.VarChar(100)
  pacientes       pacientes[]
}

model estados_consentimiento {
  id_estado_consentimiento Int                        @id @default(autoincrement())
  codigo                   String                     @unique @db.VarChar(50)
  descripcion              String                     @db.VarChar(150)
  consentimientos_paciente consentimientos_paciente[]
}

model estados_examen {
  id_estado_examen      Int                     @id @default(autoincrement())
  codigo                String                  @unique @db.VarChar(50)
  descripcion           String                  @db.VarChar(150)
  examenes_diagnosticos examenes_diagnosticos[]
}

model estados_programa_paciente {
  id_estado_programa_paciente Int                  @id @default(autoincrement())
  codigo                      String               @unique @db.VarChar(50)
  descripcion                 String               @db.VarChar(150)
  programas_paciente          programas_paciente[]
}

model estados_seguimiento {
  id_estado_seguimiento       Int                           @id @default(autoincrement())
  codigo                      String                        @unique @db.VarChar(50)
  descripcion                 String                        @db.VarChar(150)
  eventos_seguimiento_cronico eventos_seguimiento_cronico[]
  seguimientos_cronicos       seguimientos_cronicos[]
}

model eventos_seguimiento_cronico {
  id_evento              Int                   @id @default(autoincrement())
  id_seguimiento_cronico Int
  id_atencion            Int?
  fecha_programada       DateTime?             @db.Date
  fecha_realizada        DateTime?             @db.Date
  id_estado_seguimiento  Int?
  comentarios            String?
  atenciones_salud       atenciones_salud?     @relation(fields: [id_atencion], references: [id_atencion], onDelete: NoAction, onUpdate: NoAction)
  estados_seguimiento    estados_seguimiento?  @relation(fields: [id_estado_seguimiento], references: [id_estado_seguimiento], onDelete: NoAction, onUpdate: NoAction)
  seguimientos_cronicos  seguimientos_cronicos @relation(fields: [id_seguimiento_cronico], references: [id_seguimiento_cronico], onDelete: Cascade, onUpdate: NoAction)
}

model examenes_diagnosticos {
  id_examen          Int               @id @default(autoincrement())
  id_atencion        Int
  id_examen_catalogo Int
  id_estado_examen   Int?
  indicaciones       String?
  resultado          String?
  atenciones_salud   atenciones_salud  @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)
  estados_examen     estados_examen?   @relation(fields: [id_estado_examen], references: [id_estado_examen], onDelete: NoAction, onUpdate: NoAction)
  catalogo_examenes  catalogo_examenes @relation(fields: [id_examen_catalogo], references: [id_examen_catalogo], onDelete: NoAction, onUpdate: NoAction)
}

model formulas_medicas {
  id_formula              Int              @id @default(autoincrement())
  id_atencion             Int
  fecha_emision           DateTime         @default(now()) @db.Timestamp(6)
  vigencia_hasta          DateTime?        @db.Date
  instrucciones_generales String?
  firma_digital           String?
  atenciones_salud        atenciones_salud @relation(fields: [id_atencion], references: [id_atencion], onDelete: Cascade, onUpdate: NoAction)
  items_formula           items_formula[]
}

model generos {
  id_genero   Int         @id @default(autoincrement())
  codigo      String      @unique @db.VarChar(20)
  descripcion String      @db.VarChar(100)
  pacientes   pacientes[]
}

model historias_clinicas {
  id_historia                Int                        @id @default(autoincrement())
  id_paciente                Int
  id_tipo_historia           Int
  id_profesional_responsable Int?
  fecha_apertura             DateTime                   @default(now()) @db.Timestamp(6)
  estado                     String?                    @default("Finalizado") @db.VarChar(50)
  id_historia_vinculada      Int?
  motivo_consulta            String?
  enfermedad_actual          String?
  antecedentes_personales    String?
  antecedentes_familiares    String?
  atenciones_salud           atenciones_salud[]
  notas_evolucion_historia   notas_evolucion_historia[]
  historia_vinculada         historias_clinicas?         @relation("historias_vinculo", fields: [id_historia_vinculada], references: [id_historia], onDelete: NoAction, onUpdate: NoAction)
  historias_vinculadas       historias_clinicas[]        @relation("historias_vinculo")
  citas_vinculadas           citas[]                     @relation("citas_historia_vinculada")
  pacientes                  pacientes                  @relation(fields: [id_paciente], references: [id_paciente], onDelete: NoAction, onUpdate: NoAction)
  profesionales_salud        profesionales_salud?       @relation(fields: [id_profesional_responsable], references: [id_profesional], onDelete: NoAction, onUpdate: NoAction)
  tipos_historia_clinica     tipos_historia_clinica     @relation(fields: [id_tipo_historia], references: [id_tipo_historia], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_paciente], map: "idx_historia_paciente")
