  historias_clinicas historias_clinicas[]
}

model tipos_recomendacion_medica {
  id_tipo_recomendacion   Int                       @id @default(autoincrement())
  codigo                  String                    @unique @db.VarChar(50)
  descripcion             String                    @db.VarChar(150)
  recomendaciones_medicas recomendaciones_medicas[]
}

model tipos_sangre {
  id_tipo_sangre Int         @id @default(autoincrement())
  codigo         String      @unique @db.VarChar(5)
  descripcion    String?     @db.VarChar(50)
  pacientes      pacientes[]
}

model tipos_usuario {
  id_tipo_usuario Int         @id @default(autoincrement())
  codigo          String      @unique @db.VarChar(30)
  descripcion     String      @db.VarChar(100)
  pacientes       pacientes[]
}

model usuarios {
  id_usuario                Int                         @id @default(autoincrement())
  username                  String                      @unique @db.VarChar(50)
  password_hash             String                      @db.VarChar(255)
  nombre_completo           String                      @db.VarChar(150)
  email                     String?                     @unique @db.VarChar(150)
  activo                    Boolean                     @default(true)
  id_rol                    Int
  fecha_creacion            DateTime                    @default(now()) @db.Timestamp(6)
  archivos_adjuntos         archivos_adjuntos[]
  auditoria                 auditoria[]
  certificados_medicos      certificados_medicos[]
  pacientes                 pacientes[]
  plantillas_consentimiento plantillas_consentimiento[]
  profesionales_salud       profesionales_salud[]
  roles                     roles                       @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
}

model permisos {
  id_permiso     Int              @id @default(autoincrement())
  codigo         String           @unique @db.VarChar(100)
  descripcion    String           @db.VarChar(255)
  modulo         String           @db.VarChar(50)
  activo         Boolean          @default(true)
  roles_permisos roles_permisos[]
}

model roles_permisos {
  id_rol_permiso Int      @id @default(autoincrement())
  id_rol         Int
  id_permiso     Int
  concedido      Boolean  @default(true)
  permisos       permisos @relation(fields: [id_permiso], references: [id_permiso], onDelete: Cascade, onUpdate: NoAction)
  roles          roles    @relation(fields: [id_rol], references: [id_rol], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id_rol, id_permiso], map: "uq_rol_permiso")
}
